{
  "name": "easyvet",
  "private": true,
  "version": "0.1.0",
  "description": "EasyVet monorepo",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "api:dev": "pnpm --filter api start:dev",
    "web:dev": "pnpm --filter web dev"
  }
}

