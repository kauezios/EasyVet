generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PatientSex {
  MALE
  FEMALE
  UNKNOWN
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
}

model Tutor {
  id        String    @id @default(cuid())
  name      String
  document  String?   @unique
  phone     String?
  email     String?
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  patients Patient[]
  appointments Appointment[]

  @@index([name])
}

model Patient {
  id            String      @id @default(cuid())
  tutorId       String
  name          String
  species       String
  breed         String?
  sex           PatientSex  @default(UNKNOWN)
  birthDate     DateTime?
  currentWeight Float?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  tutor Tutor @relation(fields: [tutorId], references: [id])
  appointments Appointment[]

  @@index([name])
  @@index([tutorId])
}

model Appointment {
  id               String            @id @default(cuid())
  tutorId          String
  patientId        String
  veterinarianName String
  startsAt         DateTime
  endsAt           DateTime
  reason           String
  status           AppointmentStatus @default(SCHEDULED)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  canceledAt       DateTime?

  tutor   Tutor   @relation(fields: [tutorId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])

  @@index([startsAt])
  @@index([status])
  @@index([veterinarianName, startsAt])
  @@index([patientId])
  @@index([tutorId])
}

model AuditEvent {
  id         String   @id @default(cuid())
  actorId    String?
  entity     String
  entityId   String
  action     String
  summary    String?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
}

