generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PatientSex {
  MALE
  FEMALE
  UNKNOWN
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
}

enum MedicalRecordStatus {
  DRAFT
  FINALIZED
}

enum AccessRole {
  ADMIN
  VETERINARIAN
  RECEPTION
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         AccessRole @default(VETERINARIAN)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([role])
  @@index([active])
}

model Tutor {
  id        String    @id @default(cuid())
  name      String
  document  String?   @unique
  phone     String?
  email     String?
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  patients Patient[]
  appointments Appointment[]

  @@index([name])
}

model Patient {
  id            String      @id @default(cuid())
  tutorId       String
  name          String
  species       String
  breed         String?
  sex           PatientSex  @default(UNKNOWN)
  birthDate     DateTime?
  currentWeight Float?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  tutor Tutor @relation(fields: [tutorId], references: [id])
  appointments Appointment[]

  @@index([name])
  @@index([tutorId])
}

model Appointment {
  id               String            @id @default(cuid())
  tutorId          String
  patientId        String
  veterinarianName String
  startsAt         DateTime
  endsAt           DateTime
  reason           String
  status           AppointmentStatus @default(SCHEDULED)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  canceledAt       DateTime?

  tutor   Tutor   @relation(fields: [tutorId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])
  medicalRecord MedicalRecord?

  @@index([startsAt])
  @@index([status])
  @@index([veterinarianName, startsAt])
  @@index([patientId])
  @@index([tutorId])
}

model MedicalRecord {
  id                    String            @id @default(cuid())
  appointmentId         String            @unique
  status                MedicalRecordStatus @default(DRAFT)
  chiefComplaint        String?
  symptomsOnset         String?
  clinicalHistory       String?
  physicalExam          String?
  presumptiveDiagnosis  String?
  conduct               String?
  guidance              String?
  recommendedReturnAt   DateTime?
  finalizedAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@index([status])
}

model AuditEvent {
  id         String   @id @default(cuid())
  actorId    String?
  entity     String
  entityId   String
  action     String
  summary    String?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
}

model ClinicScheduleSettings {
  id                          String   @id @default("default")
  consultationDurationMinutes Int      @default(30)
  openingTime                 String   @default("08:00")
  closingTime                 String   @default("18:00")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

